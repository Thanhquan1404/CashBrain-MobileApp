# CashBrain Backend - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!

# Flask Configuration
FLASK_ENV=production

# Security Keys (Generate using: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars

# Database URLs
# Format: mysql+pymysql://username:password@host:port/database_name
DATABASE_URL=mysql+pymysql://root:password@localhost/auth_service_db
FINANCE_DATABASE_URL=mysql+pymysql://root:password@localhost/finance_db
CHATBOT_DATABASE_URL=mysql+pymysql://root:password@localhost/chatbot_db

# Optional: Additional Configuration
# SQLALCHEMY_ECHO=false
# JWT_ACCESS_TOKEN_EXPIRES=36000
# JWT_REFRESH_TOKEN_EXPIRES=864000
